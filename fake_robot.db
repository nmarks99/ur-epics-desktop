record(ao, "$(P)Receive:Joint1") {
    field(VAL, 0.0)
    field(PREC, 4)
}
record(ao, "$(P)Receive:Joint2") {
    field(VAL, 0.0)
    field(PREC, 4)
}
record(ao, "$(P)Receive:Joint3") {
    field(VAL, 0.0)
    field(PREC, 4)
}
record(ao, "$(P)Receive:Joint4") {
    field(VAL, 0.0)
    field(PREC, 4)
}
record(ao, "$(P)Receive:Joint5") {
    field(VAL, 0.0)
    field(PREC, 4)
}
